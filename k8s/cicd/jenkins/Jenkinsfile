pipeline {
    agent any

    environment {
        HARBOR_URL      = '192.168.0.170:30000'
        HARBOR_PROJECT  = 'alphacar'
        HARBOR_CRED_ID  = 'harbor-cred'
        GIT_CREDENTIAL_ID = 'github-cred'
        MANIFEST_REPO_URL = 'https://github.com/Alphacar-project/alphacar-k8s.git'
        SERVICES = "aichat community main mypage news quote search"
    }

    stages {
        stage('1. Prepare') {
            steps {
                cleanWs()
                checkout scm
                script {
                    env.GIT_SHA = sh(returnStdout: true, script: 'git rev-parse --short HEAD').trim()
                    env.FULL_VERSION = "1.0.${currentBuild.number}-${env.GIT_SHA}"
                }
            }
        }

        stage('2. Quality & Security Analysis') {
            steps {
                script {
                    def scannerHome = tool name: 'sonar-scanner'
                    def serviceList = env.SERVICES.split(' ')

                    // 서버 리소스 보호를 위해 순차 분석하되, 속도 옵션 적용
                    for (service in serviceList) {
                        stage("Analysis: ${service}") {
                            echo "🔍 [${service}] 분석 시작..."
                            
                            // 2-1. 소스 경로 유연성 체크 (src/main/java가 없으면 서비스 루트 사용)
                            def sonarSrc = "dev/alphacar/backend/${service}"
                            def hasJavaSrc = sh(script: "[ -d 'dev/alphacar/backend/${service}/src/main/java' ]", returnStatus: true) == 0
                            if (hasJavaSrc) { sonarSrc = "dev/alphacar/backend/${service}/src/main/java" }

                            // 2-2. SonarQube 실행
                            withSonarQubeEnv('SonarQube') {
                                sh """
                                    ${scannerHome}/bin/sonar-scanner \
                                    -Dsonar.projectKey=alphacar-${service} \
                                    -Dsonar.projectName=alphacar-${service} \
                                    -Dsonar.sources=${sonarSrc} \
                                    -Dsonar.host.url=http://192.168.0.170:32000 \
                                    -Dsonar.analysis.cache=true \
                                    -Dsonar.scanner.timeout=300 \
                                    -Dsonar.exclusions=**/test/**,**/resources/**,**/*.xml,**/*.html,**/*.js
                                """
                            }

                            // 2-3. Trivy 보안 스캔 (소나큐브 분석 직후 실행)
                            echo "🛡️ [${service}] Trivy 이미지 스캔 대기 중 (빌드 후 진행 가능하므로 fs 스캔 실시)"
                            sh "trivy fs --severity CRITICAL,HIGH --exit-code 0 dev/alphacar/backend/${service}"
                        }
                    }
                }
            }
        }

        stage('3. 고속 병렬 빌드 & 푸시') {
            steps {
                script {
                    def buildTasks = [:]
                    env.SERVICES.split(' ').each { service ->
                        buildTasks["Build-${service}"] = {
                            dir("dev/alphacar/backend/${service}") {
                                def imageTag = "${HARBOR_URL}/${HARBOR_PROJECT}/alphacar-${service}:${env.FULL_VERSION}"
                                sh "docker build -t ${imageTag} ."
                                
                                withCredentials([usernamePassword(credentialsId: "${env.HARBOR_CRED_ID}", usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                                    sh "echo '${PASS}' | docker login ${HARBOR_URL} -u ${USER} --password-stdin"
                                    sh "docker push ${imageTag}"
                                }
                            }
                        }
                    }
                    parallel buildTasks
                }
            }
        }

        stage('4. GitOps Update') {
            steps {
                script {
                    dir('manifest-update') {
                        checkout([$class: 'GitSCM', branches: [[name: 'main']], userRemoteConfigs: [[url: "${env.MANIFEST_REPO_URL}", credentialsId: "${env.GIT_CREDENTIAL_ID}"]] ])
                        env.SERVICES.split(' ').each { service ->
                            sh "sed -i 's|image: .*/alphacar-${service}:.*|image: ${HARBOR_URL}/${HARBOR_PROJECT}/alphacar-${service}:${env.FULL_VERSION}|' k8s/backend/${service}-backend.yaml"
                        }
                        sh """
                            git config user.email "jenkins@alphacar.com"
                            git config user.name "Jenkins-CI"
                            git add .
                            if [ -n "\$(git status --porcelain)" ]; then
                                git commit -m "Deploy ${env.FULL_VERSION} [skip ci]"
                                git push origin HEAD:main
                            fi
                        """
                    }
                }
            }
        }
    }
}
