pipeline {
    agent any

    environment {
        HARBOR_URL      = '192.168.0.170:30000'
        HARBOR_PROJECT  = 'alphacar'
        HARBOR_CRED_ID  = 'harbor-cred'
        GIT_CREDENTIAL_ID = 'github-cred'
        MANIFEST_REPO_URL = 'https://github.com/Alphacar-project/alphacar-k8s.git'
        SERVICES = "aichat community main mypage news quote search"
    }

    stages {
        stage('1. Prepare') {
            steps {
                cleanWs()
                checkout scm
                script {
                    env.GIT_SHA = sh(returnStdout: true, script: 'git rev-parse --short HEAD').trim()
                    env.FULL_VERSION = "1.0.${currentBuild.number}-${env.GIT_SHA}"
                    
                    // Trivy 설치 및 환경 구성
                    sh '''
                        if ! command -v trivy &> /dev/null; then
                            echo "📦 Trivy 설치 진행..."
                            curl -sfL https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh | sh -s -- -b /tmp
                        fi
                    '''
                }
            }
        }

        stage('2. Security & Quality Analysis') {
            steps {
                script {
                    def scannerHome = tool name: 'sonar-scanner'
                    // split 결과를 toList()로 변환하여 에러 방지
                    def serviceList = env.SERVICES.split(' ').toList()

                    for (service in serviceList) {
                        echo "🔍 [${service}] 분석 및 보안 스캔 시작..."
                        
                        // SonarQube (중요 소스만 검사하여 서버 부하 감소)
                        withSonarQubeEnv('SonarQube') {
                            sh """
                                ${scannerHome}/bin/sonar-scanner \
                                -Dsonar.projectKey=alphacar-${service} \
                                -Dsonar.analysis.cache=true \
                                -Dsonar.sources=dev/alphacar/backend/${service} \
                                -Dsonar.inclusions=**/src/main/java/** \
                                -Dsonar.host.url=http://192.168.0.170:32000 \
                                -Dsonar.scanner.timeout=300 \
                                -Dsonar.exclusions=**/test/**,**/resources/**,**/*.xml
                            """
                        }

                        // Trivy 스캔 (파일 시스템 모드)
                        echo "🛡️ [${service}] Trivy 보안 스캔..."
                        sh "/tmp/trivy fs --severity CRITICAL,HIGH --exit-code 0 dev/alphacar/backend/${service} || echo 'Trivy 스캔 실패'"
                    }
                }
            }
        }

        stage('3. 고속 분할 빌드 & 푸시') {
            steps {
                script {
                    // [에러 수정] Array를 List로 변환한 후 2개씩 분할
                    def serviceList = env.SERVICES.split(' ').toList()
                    def chunks = serviceList.collate(2) 

                    for (chunk in chunks) {
                        def buildTasks = [:]
                        chunk.each { service ->
                            def currentService = service // 클로저 변수 고정
                            buildTasks["Build-${currentService}"] = {
                                dir("dev/alphacar/backend/${currentService}") {
                                    def imageTag = "${HARBOR_URL}/${HARBOR_PROJECT}/alphacar-${currentService}:${env.FULL_VERSION}"
                                    
                                    echo "🐳 ${currentService} 빌드 및 푸시..."
                                    sh "docker build -t ${imageTag} ."
                                    
                                    withCredentials([usernamePassword(credentialsId: "${env.HARBOR_CRED_ID}", usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                                        sh """
                                            echo '${PASS}' | docker login ${HARBOR_URL} -u ${USER} --password-stdin
                                            docker push ${imageTag}
                                        """
                                    }
                                }
                            }
                        }
                        // 2개 단위로만 병렬 실행 (Pod OOM 방지)
                        parallel buildTasks
                    }
                }
            }
        }

        stage('4. GitOps Update') {
            steps {
                script {
                    dir('manifest-update') {
                        checkout([$class: 'GitSCM', branches: [[name: 'main']], userRemoteConfigs: [[url: "${env.MANIFEST_REPO_URL}", credentialsId: "${env.GIT_CREDENTIAL_ID}"]] ])
                        env.SERVICES.split(' ').each { service ->
                            sh "sed -i 's|image: .*/alphacar-${service}:.*|image: ${HARBOR_URL}/${HARBOR_PROJECT}/alphacar-${service}:${env.FULL_VERSION}|' k8s/backend/${service}-backend.yaml"
                        }
                        sh """
                            git config user.email "jenkins@alphacar.com"
                            git config user.name "Jenkins-CI"
                            git add .
                            if [ -n "\$(git status --porcelain)" ]; then
                                git commit -m "Update images to ${env.FULL_VERSION} [skip ci]"
                                git push origin HEAD:main
                            fi
                        """
                    }
                }
            }
        }
    }
}
